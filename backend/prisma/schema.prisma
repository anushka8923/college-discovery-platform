generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id                  Int      @id @default(autoincrement())
  name                String
  location            String
  fees                Int
  rating              Float
  mainCourse          String
  courses             String[]
  placementPercentage Float
  description         String
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reviews Review[]
  cutoffs Cutoff[]

  @@index([name])
  @@index([location])
  @@index([fees])
}

model Review {
  id          Int      @id @default(autoincrement())
  collegeId   Int
  studentName String
  rating      Float
  comment     String
  createdAt   DateTime @default(now())

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Cutoff {
  id        Int    @id @default(autoincrement())
  collegeId Int
  exam      String
  minRank   Int
  maxRank   Int
  course    String

  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([exam, minRank, maxRank])
  @@index([collegeId])
}
